{
  "name": "llm-shim",
  "version": "1.0.0",
  "description": "Lightweight shim that accepts OpenAI-compatible LLM requests and proxies to LM Studio",
  "main": "dist/index.js",
  "bin": {
    "llm-shim": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts"
  },
  "keywords": [
    "openai",
    "lmstudio",
    "shim",
    "proxy"
  ],
  "license": "MIT",
  "dependencies": {
    "commander": "^12.1.0",
    "express": "^4.21.0",
    "node-datachannel": "^0.12.0",
    "parquetjs-lite": "^0.8.7",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.6.0"
  }
}
