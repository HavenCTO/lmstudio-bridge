# LM Studio Bridge Data Recovery - Environment Configuration
# Copy this file to .env.local and fill in your values

# ============================================
# TACo Decryption Configuration
# ============================================

# TACo network domain (lynx, ursula, datil-dev, datil-test, datil)
TACO_DOMAIN=lynx

# Ritual ID used for encryption
TACO_RITUAL_ID=27

# Blockchain RPC URL for TACo interactions
TACO_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Private key for wallet authentication (DO NOT commit to git!)
# This is required for decrypting TACo-encrypted data
TEST_PRIVATE_KEY=

# ============================================
# IPFS Configuration
# ============================================

# Primary IPFS gateway for retrieval
IPFS_GATEWAY=https://ipfs.io

# Alternative gateways (comma-separated)
IPFS_ALTERNATIVE_GATEWAYS=https://cloudflare-ipfs.com,https://dweb.link,https://gateway.pinata.cloud

# ============================================
# Filecoin/Synapse Configuration
# ============================================

# Filecoin RPC WebSocket URL
FILECOIN_RPC_URL=wss://api.calibration.node.glif.io/rpc/v1

# Private key for Filecoin transactions (optional, for Synapse operations)
SYNAPSE_PRIVATE_KEY=

# ============================================
# Output Configuration
# ============================================

# Default output directory for recovered data
OUTPUT_DIR=./recovered

# Enable verbose logging
VERBOSE=false
