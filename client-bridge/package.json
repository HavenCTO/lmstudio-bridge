{
  "name": "llm-client-bridge",
  "version": "1.0.0",
  "description": "Client-side bridge that accepts OpenAI-compatible HTTP requests and proxies them to the LLM shim over WebRTC",
  "main": "dist/index.js",
  "bin": {
    "llm-client-bridge": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts"
  },
  "keywords": ["openai", "webrtc", "bridge", "proxy"],
  "license": "MIT",
  "dependencies": {
    "express": "5.2.1",
    "commander": "14.0.3",
    "node-datachannel": "0.32.1"
  },
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/node": "25.3.0",
    "typescript": "5.9.3",
    "ts-node": "10.9.2"
  }
}
